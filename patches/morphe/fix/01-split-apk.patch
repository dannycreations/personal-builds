+inspect_apk() {
+	local apk=$1
+	if ! unzip -l "$apk" AndroidManifest.xml >/dev/null 2>&1; then
+		pr "Splitted APK detected, merging..."
+		local tmp_merged="${apk}.merged.apk"
+		merge_splits "$apk" "$tmp_merged" || return 1
+		mv -f "$tmp_merged" "$apk"
+	fi
+}
