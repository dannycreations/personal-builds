+      this.credentials = {
+        access_token: responseBody.access_token,
+        refresh_token: responseBody.refresh_token || this.credentials.refresh_token,
+        token_type: responseBody.token_type || "Bearer",
+        expiry_date: responseBody.expires_in ? Date.now() + responseBody.expires_in * 1000 : Date.now() + 3600000,
+      }
