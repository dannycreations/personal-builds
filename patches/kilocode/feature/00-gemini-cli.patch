+function convertPromptToGemini(prompt: Parameters<LanguageModelV2["doGenerate"]>[0]["prompt"]) {
+  const contents: any[] = []
+  const systemParts: any[] = []
+
+  for (const msg of prompt) {
+    const { role, content, providerOptions } = msg
+    const isSystem = role === "system"
+    const opts = providerOptions?.["gemini-cli"]
+
+    if (typeof content === "string") {
+      if (isSystem) {
+        if (content) systemParts.push({ text: content })
+      } else {
+        contents.push({ role: role === "assistant" ? "model" : "user", parts: [{ text: content }] })
+      }
+      continue
+    }
+
+    const parts: any[] = []
+    for (const it of content as any[]) {
+      if ((it.type === "text" || it.type === "reasoning") && it.text) {
+        const res: any = { text: it.text }
+        if (it.type === "reasoning") res.thought = true
+        const sig = it.thoughtSignature || opts?.thoughtSignature
+        if (sig) res.thoughtSignature = sig
+        parts.push(res)
+      } else if (it.type === "file") {
+        const mime = it.mediaType || it.mimeType
+        if (mime?.startsWith("image/")) parts.push({ inlineData: { mimeType: mime, data: it.data } })
+      } else if (it.type === "tool-call") {
+        const res: any = { functionCall: { name: it.toolName, args: it.args } }
+        if (it.thoughtSignature) res.thoughtSignature = it.thoughtSignature
+        parts.push(res)
+      } else if (it.type === "tool-result") {
+        parts.push({ functionResponse: { name: it.toolName, response: { result: it.result } } })
+      }
+    }
+
+    if (parts.length > 0) {
+      if (isSystem) {
+        for (const p of parts) if (p.text) systemParts.push(p)
+      } else {
+        contents.push({ role: role === "assistant" ? "model" : "user", parts })
+      }
+    }
+  }
+
+  return { systemInstruction: systemParts.length ? { parts: systemParts } : undefined, contents }
+}
+
+function convertToolsToGemini(
+  tools: Parameters<LanguageModelV2["doGenerate"]>[0]["tools"],
+  toolChoice: Parameters<LanguageModelV2["doGenerate"]>[0]["toolChoice"],
+) {
+  if (!tools || tools.length === 0) return undefined
+
+  const declarations = tools
+    .map((tool) => {
+      if (tool.type === "function") {
+        return {
+          name: tool.name,
+          description: tool.description,
+          parameters: sanitizeGeminiSchema(tool.inputSchema),
+        }
+      }
+    })
+    .filter(Boolean)
+
+  const mode = toolChoice?.type === "none" ? "NONE" : toolChoice?.type === "required" ? "ANY" : "AUTO"
+
+  return {
+    tools: [{ functionDeclarations: declarations }],
+    toolConfig: { functionCallingConfig: { mode } },
+  }
+}
+
+function sanitizeGeminiSchema(schema: any): any {
+  if (schema == null || typeof schema !== "object") return schema
+  if (Array.isArray(schema)) {
+    const res = schema.map(sanitizeGeminiSchema)
+    return res.every((v, i) => v === schema[i]) ? schema : res
+  }
+
+  const ref = schema.ref || schema.$ref
+  const hasStruct = "type" in schema || "properties" in schema || "items" in schema
+  const res: any = {}
+  let changed = false
+
+  for (const k in schema) {
+    if (k === "$schema" || ((k === "ref" || k === "$ref") && hasStruct)) {
+      changed = true
+      continue
+    }
+    if (ref && !hasStruct && !["ref", "$ref", "description", "default"].includes(k)) {
+      changed = true
+      continue
+    }
+    const val = schema[k]
+    const sVal = sanitizeGeminiSchema(val)
+    const nK = k === "ref" || k === "$ref" ? "ref" : k
+    if (sVal !== val || nK !== k) changed = true
+    res[nK] = sVal
+  }
+
+  if (!changed && Object.keys(res).length === Object.keys(schema).length) return schema
+  return res
+}
+
+function mapGeminiFinishReason(
+  finishReason: string | null | undefined,
+  hasToolCall: boolean,
+): LanguageModelV2FinishReason {
+  if (hasToolCall) return "tool-calls"
+  switch (finishReason) {
+    case "STOP":
+    case "stop":
+      return "stop"
+    case "MAX_TOKENS":
+    case "max_tokens":
+      return "length"
+    case "SAFETY":
+    case "RECITATION":
+    case "OTHER":
+      return "content-filter"
+    default:
+      return "stop"
+  }
+}

