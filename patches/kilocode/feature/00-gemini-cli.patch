+  private async ensureAuthenticated(): Promise<void> {
+    if (!this.credentials) {
+      let geminiCliOAuthPath = this.config.geminiCliOAuthPath || Env.get("GOOGLE_OAUTH_PATH")
+      if (!geminiCliOAuthPath) {
+        try {
+          const content = await Bun.file(join(dirname(OAUTH_DEFAULT_PATH), ".env")).text()
+          const match = content.match(/GOOGLE_OAUTH_PATH=["']?([^"'\r\n\s;]+)["']?/)
+          const oauthPath = match ? match[1].trim() : ""
+          if (oauthPath) geminiCliOAuthPath = oauthPath
+        } catch {}
+      }
+
+      this.credPath = geminiCliOAuthPath || OAUTH_DEFAULT_PATH
+
+      const file = Bun.file(this.credPath)
+      if (await file.exists()) {
+        this.credentials = await file.json()
+      }
+    }
+
+    if (this.credentials && this.credentials.expiry_date - 60_000 < Date.now()) {
+      const { value: responseBody } = await postJsonToApi({
+        url: "https://oauth2.googleapis.com/token",
+        body: {
+          client_id: OAUTH_CLIENT_ID,
+          client_secret: OAUTH_CLIENT_SECRET,
+          refresh_token: this.credentials.refresh_token,
+          grant_type: "refresh_token",
+        },
+        failedResponseHandler: createJsonResponseHandler(z.any()),
+        successfulResponseHandler: createJsonResponseHandler(
+          z.object({
+            access_token: z.string(),
+            refresh_token: z.string().optional(),
+            token_type: z.string().optional(),
+            expires_in: z.number().optional(),
+          }),
+        ),
+        fetch: this.config.fetch,
+      })
