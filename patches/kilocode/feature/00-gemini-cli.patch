+  private async discoverProjectId(): Promise<void> {
+    if (this.projectId) return
+
+    if (this.config.geminiCliProjectId) {
+      this.projectId = this.config.geminiCliProjectId
+      return
+    }
+
+    const projectId = Env.get("GOOGLE_CLOUD_PROJECT")
+    if (projectId) {
+      this.projectId = projectId
+      return
+    }
+
+    try {
+      const content = await Bun.file(join(dirname(this.credPath), ".env")).text()
+      const match = content.match(/GOOGLE_CLOUD_PROJECT=["']?([^"'\r\n\s;]+)["']?/)
+      const projectId = match ? match[1].trim() : ""
+      if (projectId) {
+        this.projectId = projectId
+        return
+      }
+    } catch {}
+
+    const metadata = { ideType: "IDE_UNSPECIFIED", platform: "PLATFORM_UNSPECIFIED", pluginType: "GEMINI" }
+    const load = await this.callEndpoint("loadCodeAssist", {
+      cloudaicompanionProject: this.projectId,
+      metadata: { ...metadata, duetProject: this.projectId },
+    })
+
+    if (load.cloudaicompanionProject) {
+      this.projectId = load.cloudaicompanionProject
+      return
+    }
+
+    const tierId = load.allowedTiers?.find((t: any) => t.isDefault)?.id || "free-tier"
+    let onboard = await this.callEndpoint("onboardUser", { tierId, cloudaicompanionProject: undefined, metadata })
+
+    if (!onboard.done && onboard.name) {
+      const op = onboard.name
+      const fetchFn = this.config.fetch || fetch
+      while (!onboard.done) {
+        await new Promise((f) => setTimeout(f, 5000))
+        const response = await fetchFn(`${this.config.baseURL}/${op}`, {
+          method: "GET",
+          headers: {
+            Authorization: `Bearer ${this.credentials?.access_token}`,
+            "Content-Type": "application/json",
+          },
+        })
+        onboard = await response.json()
+      }
+    }
+    this.projectId = onboard.response?.cloudaicompanionProject?.id
+  }
+
+  private async callEndpoint(method: string, body: any, retry = true): Promise<any> {
+    try {
+      await this.ensureAuthenticated()
+
+      const { value: responseBody } = await postJsonToApi({
+        url: `${this.config.baseURL}:${method}`,
+        headers: { Authorization: `Bearer ${this.credentials?.access_token}` },
+        body,
+        failedResponseHandler: createJsonResponseHandler(z.any()),
+        successfulResponseHandler: createJsonResponseHandler(z.any()),
+        fetch: this.config.fetch,
+      })
+
+      return responseBody
+    } catch (error: any) {
+      if (error.code === 401 && retry) {
+        this.credentials = undefined
+        return this.callEndpoint(method, body, false)
+      }
+      throw error
+    }
+  }
+
+  private async prepareRequest(options: Parameters<LanguageModelV2["doGenerate"] | LanguageModelV2["doStream"]>[0]) {
+    await this.ensureAuthenticated()
+    await this.discoverProjectId()
+
+    const geminiOptions = options.providerOptions?.[this.provider]
+    const sessionId = geminiOptions?.session_id
+    const userPromptId = sessionId ? `${sessionId}########${++this.turnCount}` : undefined
+    const { systemInstruction, contents } = this.mapPromptToGemini(options.prompt)
+    const toolSettings = this.mapToolsToGemini(options.tools, options.toolChoice)
+
+    const body = {
+      model: this.modelId,
+      project: this.projectId,
+      user_prompt_id: userPromptId,
+      request: {
+        systemInstruction,
+        contents,
+        ...(toolSettings?.tools ? { tools: toolSettings.tools } : {}),
+        ...(toolSettings?.toolConfig ? { toolConfig: toolSettings.toolConfig } : {}),
+        generationConfig: {
+          ...(options.temperature != null ? { temperature: options.temperature } : {}),
+          ...(options.topP != null ? { topP: options.topP } : {}),
+          ...(options.topK != null ? { topK: options.topK } : {}),
+          ...(options.maxOutputTokens != null ? { maxOutputTokens: options.maxOutputTokens } : {}),
+          ...(geminiOptions?.thinkingConfig ? { thinkingConfig: geminiOptions.thinkingConfig } : {}),
+        },
+        ...(sessionId ? { session_id: sessionId } : {}),
+      },
+    }
+
+    const headers = combineHeaders(
+      {
+        Authorization: `Bearer ${this.credentials?.access_token}`,
+        "User-Agent": `GeminiCLI/${Installation.VERSION}/${this.modelId} (${platform()}; ${arch()})`,
+      },
+      options.headers,
+    )
+
+    return { headers, body }
+  }
+
+  private mapPromptToGemini(prompt: LanguageModelV2Prompt) {
+    let systemInstruction: any = undefined
+    const contents: any[] = []
+
+    for (const message of prompt) {
+      if (message.content.length < 1) continue
+
+      if (message.role === "system") {
+        systemInstruction = {
+          role: "user",
+          parts: [{ text: message.content }],
+        }
+        continue
+      }
+
+      const role = message.role === "assistant" ? "model" : "user"
+      const parts: unknown[] = []
+
+      for (const part of message.content) {
+        if (part.type === "text") {
+          parts.push({ text: part.text })
+        } else if (part.type === "file") {
+          parts.push({
+            inlineData: {
+              mimeType: part.mediaType,
+              data: part.data,
+            },
+          })
+        } else if (part.type === "tool-call") {
+          const thoughtSignature = part.providerOptions?.[this.provider]?.thoughtSignature
+          parts.push({
+            functionCall: {
+              name: part.toolName,
+              args: part.input,
+            },
+            thoughtSignature: thoughtSignature ?? "skip_thought_signature_validator",
+          })
+        } else if (part.type === "tool-result") {
+          parts.push({
+            functionResponse: {
+              id: part.toolCallId,
+              name: part.toolName,
+              response: { output: part.output.value },
+            },
+          })
+        }
+      }
+
+      contents.push({ role, parts })
+    }
+
+    return { systemInstruction, contents }
+  }
+
+  private mapToolsToGemini(tools?: any[], toolChoice?: LanguageModelV2ToolChoice) {
+    if (!tools || tools.length === 0) return {}
+
+    const functionDeclarations = tools
+      .map((tool) => {
+        if (tool.type === "function") {
+          return {
+            name: tool.name,
+            description: tool.description ?? "",
+            parametersJsonSchema: tool.inputSchema,
+          }
+        }
+        return undefined
+      })
+      .filter(Boolean)
+
+    const mappedTools = [{ functionDeclarations }]
+
+    let toolConfig: any = undefined
+    if (toolChoice) {
+      if (toolChoice.type === "auto") {
+        toolConfig = { functionCallingConfig: { mode: "AUTO" } }
+      } else if (toolChoice.type === "required") {
+        toolConfig = { functionCallingConfig: { mode: "ANY" } }
+      } else if (toolChoice.type === "tool") {
+        toolConfig = {
+          functionCallingConfig: {
+            mode: "ANY",
+            allowedFunctionNames: [toolChoice.toolName],
+          },
+        }
+      }
+    }
+
+    return { tools: mappedTools, toolConfig }
+  }
+}

