+                      : undefined,
+                  })
+                }
+              }
+            }
+
+            if (response.usageMetadata) usage = response.usageMetadata
+            if (candidate?.finishReason) {
+              if (activeToolCall) {
+                finishReason = "tool-calls"
+                return
+              }
+
+              const reason = candidate?.finishReason
+              if (reason === "STOP") finishReason = "stop"
+              else if (reason === "MAX_TOKENS") finishReason = "length"
+              else if (reason === "SAFETY") finishReason = "content-filter"
+              else if (reason === "RECITATION") finishReason = "content-filter"
+              else if (reason === "OTHER") finishReason = "other"
+            }
+          },
+          flush(controller) {
+            if (activeReasoning) {
+              controller.enqueue({ type: "reasoning-end", id: activeReasoning })
+              activeReasoning = null
+            }
+            if (activeText) {
+              controller.enqueue({ type: "text-end", id: activeText })
+              activeText = null
+            }
+            if (activeToolCall) {
+              controller.enqueue({ type: "tool-input-end", id: activeToolCall })
+              activeToolCall = null
+            }
+
+            controller.enqueue({
+              type: "finish",
+              finishReason,
+              usage: {
+                inputTokens: usage?.promptTokenCount ?? 0,
+                outputTokens: usage?.candidatesTokenCount ?? 0,
+                totalTokens: usage?.totalTokenCount ?? 0,
+              },
+            })
+          },
+        }),
+      ),
+    }
+  }
